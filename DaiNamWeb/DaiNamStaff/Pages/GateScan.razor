@page "/gate"
@inject GateService GateSvc
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="gate-page">
    <div class="header-section">
        <h2><i class="bi bi-qr-code-scan"></i> Soát vé cổng</h2>
        <div class="location-selectors">
            <select @bind="selectedAreaId" @bind:after="OnAreaChanged">
                <option value="">-- Chọn Khu Vực --</option>
                @foreach (var area in areas)
                {
                    <option value="@area.Id">@area.TenKhuVuc</option>
                }
            </select>

            <select @bind="selectedGameId">
                <option value="">-- Chọn Trò Chơi (Nếu có) --</option>
                @foreach (var game in filteredGames)
                {
                    <option value="@game.Id">@game.TenTroChoi</option>
                }
            </select>
        </div>
    </div>

    <!-- camera scanner -->
    <div class="scanner-box">
        <div id="qr-reader" style="width:100%"></div>
    </div>

    <!-- hoặc nhập tay -->
    <div class="manual-input">
        <input type="text" @bind="manualCode" placeholder="Nhập mã vạch thủ công..." 
               @onkeydown="OnKeyDown" />
        <button class="btn-scan" @onclick="ManualScan" disabled="@(scanning || string.IsNullOrEmpty(manualCode))">
            <i class="bi bi-search"></i>
        </button>
    </div>

    <!-- kết quả -->
    @if (result != null)
    {
        <div class="scan-result @(result.HopLe ? "scan-pass" : "scan-fail")">
            <div class="scan-icon">
                @if (result.HopLe)
                {
                    <i class="bi bi-check-circle-fill"></i>
                }
                else
                {
                    <i class="bi bi-x-circle-fill"></i>
                }
            </div>
            <div class="scan-info">
                @if (result.HopLe)
                {
                    <h3>PASS</h3>
                    <p><strong>@result.TenVe</strong></p>
                    <p>Còn <strong>@result.SoLuotConLai</strong> lượt</p>
                }
                else
                {
                    <h3>FAIL</h3>
                    <p>@result.LyDo</p>
                }
            </div>
        </div>
    }

    <!-- lịch sử quét gần đây -->
    <div class="scan-history">
        <h4>Lịch sử quét (Gần đây)</h4>
        @if (history.Any())
        {
            @foreach (var h in history.Take(20))
            {
                <div class="history-item @(h.HopLe ? "" : "failed")">
                    <div class="h-left">
                        <span class="h-code">@h.MaVach</span>
                        <span class="h-name">@h.TenSanPham</span>
                    </div>
                    <div class="h-right">
                        <span class="h-time">@h.ThoiGianQuet.ToString("HH:mm")</span>
                        <span class="h-status">@(h.HopLe ? "✓" : "✗")</span>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="empty-history">Chưa có lượt quét nào hôm nay</div>
        }
    </div>
</div>

@code {
    string manualCode = "";
    ScanResult? result;
    bool scanning;
    List<ScanHistoryItem> history = new();
    
    List<AreaItem> areas = new();
    List<GameItem> allGames = new();
    List<GameItem> filteredGames = new();

    int? selectedAreaId;
    int? selectedGameId;

    protected override async Task OnInitializedAsync()
    {
        areas = await GateSvc.GetAreas();
        allGames = await GateSvc.GetGames(null);
        await LoadHistory();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("initScanner", DotNetObjectReference.Create(this));
        }
    }

    async Task LoadHistory()
    {
        history = await GateSvc.GetHistory(selectedAreaId);
    }

    async Task OnAreaChanged()
    {
        selectedGameId = null;
        if (selectedAreaId.HasValue)
            filteredGames = allGames.Where(g => g.IdKhuVuc == selectedAreaId.Value).ToList();
        else
            filteredGames = new();
        
        await LoadHistory();
    }

    [JSInvokable]
    public async Task OnBarcodeScanned(string code)
    {
        if (scanning || string.IsNullOrWhiteSpace(code)) return;
        scanning = true;
        manualCode = code;
        
        result = await GateSvc.Scan(code, selectedAreaId, selectedGameId);
        
        if (result != null) 
        {
            await LoadHistory();
        }
        
        scanning = false;
        StateHasChanged();
    }

    async Task ManualScan()
    {
        if (string.IsNullOrWhiteSpace(manualCode)) return;
        await OnBarcodeScanned(manualCode.Trim());
    }

    async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ManualScan();
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("stopScanner"); } catch { }
    }
}
