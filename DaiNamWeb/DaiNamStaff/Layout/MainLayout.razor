@inherits LayoutComponentBase
@inject StaffAuthService Auth
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn)
{
    @Body
}
else
{
    <div class="staff-app">
        <header class="staff-header">
            <span class="staff-brand"><i class="bi bi-shield-check"></i> Đại Nam Staff</span>
            <span class="staff-user" @onclick="DoLogout">
                <i class="bi bi-person-circle"></i> @Auth.CurrentUser?.HoTen
            </span>
        </header>

        <main class="staff-body">
            @Body
        </main>

        <nav class="staff-nav">
            <a href="/" class="@NavClass("/")">
                <i class="bi bi-qr-code-scan"></i>
                <span>Soát vé</span>
            </a>
            <a href="/kitchen" class="@NavClass("/kitchen")">
                <i class="bi bi-fire"></i>
                <span>Lệnh bếp</span>
            </a>
        </nav>
    </div>
}

@code {
    string NavClass(string path) =>
        Nav.Uri.EndsWith(path) || (path == "/" && Nav.Uri.EndsWith("/")) ? "nav-item active" : "nav-item";

    void DoLogout()
    {
        Auth.Logout();
        Nav.NavigateTo("/login");
    }
}
