@page "/book-hotel"
@inject HotelService HotelSvc
@inject AuthService Auth
@inject NavigationManager Nav

<h2><i class="bi bi-building"></i> Đặt loại phòng khách sạn</h2>

<div class="date-picker-row">
    <div>
        <label>Ngày nhận phòng</label>
        <input type="date" @bind="checkIn" min="@DateTime.Today.ToString("yyyy-MM-dd")" @bind:event="oninput" />
    </div>
    <div>
        <label>Ngày trả phòng</label>
        <input type="date" @bind="checkOut" min="@checkIn.AddDays(1).ToString("yyyy-MM-dd")" @bind:event="oninput" />
    </div>
    <button class="btn-primary" @onclick="LoadRooms" disabled="@loading">
        @if (loading)
        {
            <i class="bi bi-arrow-repeat spin"></i> <span> Đang tìm...</span>
        }
        else
        {
            <i class="bi bi-search"></i> <span> Tìm phòng</span>
        }
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMsg))
{
    <div class="alert alert-err"><i class="bi bi-exclamation-circle"></i> @errorMsg</div>
}

@if (rooms != null)
{
    @if (!rooms.Any())
    {
        <p class="no-rooms"><i class="bi bi-inbox"></i> Không có loại phòng nào phù hợp.</p>
    }
    else
    {
        <div class="room-grid">
            @foreach (var room in rooms)
            {
                <div class="room-card @(room.SoPhongTrong == 0 ? "sold-out" : "")">
                    <div class="room-header">
                        <h3><i class="bi bi-door-closed"></i> @room.TenLoai</h3>
                        @if (room.SoPhongTrong > 0)
                        {
                            <span class="badge-available">
                                <i class="bi bi-check-circle"></i> Còn @room.SoPhongTrong phòng
                            </span>
                        }
                        else
                        {
                            <span class="badge-full"><i class="bi bi-x-circle"></i> Hết phòng</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(room.MoTa))
                    {
                        <p class="room-desc">@room.MoTa</p>
                    }

                    <div class="room-details">
                        @if (room.SoNguoiToiDa > 0)
                        {
                            <span><i class="bi bi-people"></i> Tối đa @room.SoNguoiToiDa người</span>
                        }
                        @if (room.DienTich > 0)
                        {
                            <span><i class="bi bi-aspect-ratio"></i> @room.DienTich m²</span>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(room.TienNghi))
                    {
                        <div class="room-amenities">
                            @foreach (var tn in room.TienNghi.Split(',', StringSplitOptions.TrimEntries))
                            {
                                <span class="amenity-tag">@tn</span>
                            }
                        </div>
                    }

                    <div class="room-pricing">
                        <div class="price-per-night">
                            @room.GiaMoiDem.ToString("N0") ₫ <small>/đêm</small>
                        </div>
                        <div class="price-total">
                            @{
                                int soDem = Math.Max(1, (checkOut - checkIn).Days);
                                decimal total = room.GiaMoiDem * soDem;
                                decimal coc = Math.Round(total * 0.3m, 0);
                            }
                            <span>@soDem đêm = <strong>@total.ToString("N0") ₫</strong></span>
                            <span class="deposit">
                                <i class="bi bi-shield-check"></i> Cọc 30%: <strong>@coc.ToString("N0") ₫</strong>
                            </span>
                        </div>
                    </div>

                    <button class="btn-book" @onclick="() => DoBook(room)"
                            disabled="@(room.SoPhongTrong == 0 || booking)">
                        @if (booking && selectedRoom?.IdLoaiPhong == room.IdLoaiPhong)
                        {
                            <i class="bi bi-arrow-repeat spin"></i> <span> Đang đặt...</span>
                        }
                        else
                        {
                            <i class="bi bi-calendar2-plus"></i> <span> Đặt loại phòng này</span>
                        }
                    </button>
                </div>
            }
        </div>
    }
}

@if (bookingResult != null)
{
    <div class="booking-success">
        <h3><i class="bi bi-check-circle-fill"></i> Đặt phòng thành công!</h3>
        <p>Mã đặt phòng: <strong>@bookingResult.MaDatPhong</strong></p>
        <p>Tiền phòng: @bookingResult.TienPhong.ToString("N0") ₫</p>
        <p>Tiền cọc (đã giả lập): <strong>@bookingResult.TienCoc.ToString("N0") ₫</strong></p>
        <p class="note">
            <i class="bi bi-info-circle"></i>
            Phòng cụ thể sẽ được sắp xếp khi bạn đến check-in tại quầy lễ tân.
            Nếu không đến đúng hạn, hệ thống tự động nhả phòng và cọc sẽ không được hoàn.
        </p>
    </div>
}

@code {
    DateTime checkIn = DateTime.Today.AddDays(1);
    DateTime checkOut = DateTime.Today.AddDays(2);
    List<RoomTypeInfo>? rooms;
    RoomTypeInfo? selectedRoom;
    BookingResult? bookingResult;
    bool loading, booking;
    string errorMsg = "";

    async Task LoadRooms()
    {
        if (checkOut <= checkIn) { errorMsg = "Ngày trả phòng phải sau ngày nhận phòng!"; return; }
        loading = true; errorMsg = ""; bookingResult = null;
        rooms = await HotelSvc.GetRoomTypes(checkIn, checkOut);
        loading = false;
    }

    async Task DoBook(RoomTypeInfo room)
    {
        if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        booking = true; selectedRoom = room; errorMsg = "";
        bookingResult = await HotelSvc.Book(new BookingRequest(
            Auth.CurrentUser!.IdTaiKhoan, room.IdLoaiPhong, checkIn, checkOut, null));
        if (bookingResult == null) errorMsg = "Đặt phòng thất bại. Vui lòng thử lại.";
        booking = false;
    }
}
