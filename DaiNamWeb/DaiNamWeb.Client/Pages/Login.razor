@page "/login"
@inject AuthService Auth
@inject NavigationManager Nav

<div class="auth-box">
    <h2><i class="bi bi-shield-lock"></i> Đăng nhập</h2>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(success ? "alert-ok" : "alert-err")">@message</div>
    }

    <label>Số điện thoại</label>
    <input type="tel" @bind="sdt" placeholder="0901234567" />

    <label>Mật khẩu</label>
    <input type="password" @bind="pass" />

    <button class="btn-primary" @onclick="DoLogin" disabled="@loading">
        @if (loading)
        {
            <i class="bi bi-arrow-repeat spin"></i>
            <span> Đang xử lý...</span>
        }
        else
        {
            <i class="bi bi-box-arrow-in-right"></i>
            <span> Đăng nhập</span>
        }
    </button>

    <p class="auth-link">Chưa có tài khoản? <a href="/register">Đăng ký</a></p>
</div>

@code {
    string sdt = "", pass = "", message = "";
    bool loading, success;

    async Task DoLogin()
    {
        loading = true;
        var (ok, msg) = await Auth.Login(sdt, pass);
        message = msg; success = ok; loading = false;
        if (ok) Nav.NavigateTo("/");
    }
}
