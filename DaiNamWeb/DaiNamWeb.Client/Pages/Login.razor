@page "/login"
@inject DaiNamWeb.Client.Services.AuthService Auth
@inject NavigationManager Nav

<div style="max-width:380px; margin:48px auto">
    <div class="card">
        <div class="card-header" style="text-align:center; font-size:18px"><i class="bi bi-shield-lock"></i> Đăng nhập</div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(success ? "alert-success" : "alert-danger")">@message</div>
        }

        <div class="form-group">
            <label>Số điện thoại</label>
            <input class="form-control" @bind="sdt" placeholder="0901234567" />
        </div>

        <div class="form-group">
            <label>Mật khẩu</label>
            <input class="form-control" type="password" @bind="pass" />
        </div>

        <button class="btn btn-gold btn-lg" style="width:100%" @onclick="DoLogin" disabled="@loading">
            @(loading ? "Đang xử lý..." : "Đăng nhập")
        </button>

        <div style="text-align:center; margin-top:var(--sp-16); font-size:13px; color:var(--outline)">
            Chưa có tài khoản? <a href="/register" style="color:var(--tertiary); font-weight:600">Đăng ký</a>
        </div>

        <div style="text-align:center; margin-top:var(--sp-8)">
            <a href="/staff-login" style="font-size:12px; color:var(--outline)">Đăng nhập nhân viên →</a>
        </div>
    </div>
</div>

@code {
    string sdt = "", pass = "", message = "";
    bool loading, success;

    async Task DoLogin()
    {
        loading = true;
        var (ok, msg) = await Auth.Login(sdt, pass);
        message = msg;
        success = ok;
        loading = false;
        if (ok) Nav.NavigateTo("/");
    }
}
