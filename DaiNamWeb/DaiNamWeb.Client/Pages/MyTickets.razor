@page "/my-tickets"
@inject TicketService TicketSvc
@inject HotelService HotelSvc
@inject AuthService Auth
@inject NavigationManager Nav

@if (!Auth.IsLoggedIn)
{
    <div class="auth-box">
        <p><i class="bi bi-lock"></i> Vui lòng <a href="/login">đăng nhập</a> để xem thông tin.</p>
    </div>
}
else
{
    <h2><i class="bi bi-person-circle"></i> Thông tin của tôi — @Auth.CurrentUser?.HoTen</h2>

    <div class="tab-bar">
        <button class="@(tab == 0 ? "tab-active" : "")" @onclick="() => tab = 0">
            <i class="bi bi-ticket-perforated"></i> Vé của tôi
        </button>
        <button class="@(tab == 1 ? "tab-active" : "")" @onclick="() => tab = 1">
            <i class="bi bi-building"></i> Đặt phòng
        </button>
    </div>

    @if (tab == 0)
    {
        @if (tickets == null)
        {
            <p><i class="bi bi-arrow-repeat spin"></i> Đang tải...</p>
        }
        else if (!tickets.Any())
        {
            <p><i class="bi bi-inbox"></i> Bạn chưa mua vé nào. <a href="/buy-ticket">Mua vé ngay →</a></p>
        }
        else
        {
            <div class="my-list">
                @foreach (var ve in tickets)
                {
                    <div class="my-item">
                        <div class="my-item-info">
                            <strong>@ve.TenSanPham</strong>
                            <code><i class="bi bi-upc-scan"></i> @ve.MaVach</code>
                        </div>
                        <div class="my-item-status">
                            <span class="status-badge @ve.TrangThai.ToLower()">
                                @(ve.TrangThai switch {
                                    "ChuaSuDung" => "Chưa sử dụng",
                                    "DaSuDung"   => "Đã sử dụng",
                                    "DaHuy"      => "Đã hủy",
                                    _            => ve.TrangThai
                                })
                            </span>
                            <span><i class="bi bi-arrow-repeat"></i> Còn @ve.SoLuotConLai lượt</span>
                        </div>
                    </div>
                }
            </div>
        }
    }

    @if (tab == 1)
    {
        @if (bookings == null)
        {
            <p><i class="bi bi-arrow-repeat spin"></i> Đang tải...</p>
        }
        else if (!bookings.Any())
        {
            <p><i class="bi bi-inbox"></i> Bạn chưa đặt phòng nào. <a href="/book-hotel">Đặt phòng ngay →</a></p>
        }
        else
        {
            <div class="my-list">
                @foreach (var b in bookings)
                {
                    <div class="my-item">
                        <div class="my-item-info">
                            <strong><i class="bi bi-door-closed"></i> @b.TenLoaiPhong</strong>
                            <span>
                                <i class="bi bi-calendar-range"></i>
                                @b.NgayNhanPhong.ToString("dd/MM/yyyy") → @b.NgayTraPhong.ToString("dd/MM/yyyy")
                                (@b.SoDem đêm)
                            </span>
                        </div>
                        <div class="my-item-status">
                            <span class="status-badge @b.TrangThai.ToLower()">
                                @(b.TrangThai switch {
                                    "DatTruoc" => "Đã đặt",
                                    "DangO"    => "Đang ở",
                                    "DaTra"    => "Đã trả",
                                    "DaHuy"    => "Đã hủy",
                                    _          => b.TrangThai
                                })
                            </span>
                            <span>
                                <i class="bi bi-cash-coin"></i>
                                Cọc @b.TienCoc.ToString("N0") ₫ / Tổng @b.TienPhong.ToString("N0") ₫
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    }
}

@code {
    int tab = 0;
    List<TicketInfo>? tickets;
    List<MyBookingItem>? bookings;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsLoggedIn) return;
        var id = Auth.CurrentUser!.IdTaiKhoan;
        tickets = await TicketSvc.GetMyTickets(id);
        bookings = await HotelSvc.GetMyBookings(id);
    }
}
