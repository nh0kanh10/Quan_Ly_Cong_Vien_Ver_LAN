@page "/staff-login"
@inject DaiNamWeb.Client.Services.AuthService Auth
@inject NavigationManager Nav

<div style="max-width:380px; margin:48px auto">
    <div class="card">
        <div class="card-header" style="text-align:center; font-size:18px"><i class="bi bi-person-badge"></i> Đăng nhập Nhân viên</div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-danger">@message</div>
        }

        <div class="form-group">
            <label>Tên đăng nhập</label>
            <input class="form-control" @bind="user" placeholder="admin" />
        </div>

        <div class="form-group">
            <label>Mật khẩu</label>
            <input class="form-control" type="password" @bind="pass" />
        </div>

        <button class="btn btn-primary btn-lg" style="width:100%" @onclick="DoLogin" disabled="@loading">
            @(loading ? "Đang xử lý..." : "Đăng nhập")
        </button>

        <div style="text-align:center; margin-top:var(--sp-16)">
            <a href="/login" style="font-size:12px; color:var(--outline)">← Đăng nhập khách hàng</a>
        </div>
    </div>
</div>

@code {
    string user = "", pass = "", message = "";
    bool loading;

    async Task DoLogin()
    {
        loading = true;
        var (ok, msg) = await Auth.StaffLogin(user, pass);
        if (!ok) message = msg;
        loading = false;
        if (ok) Nav.NavigateTo("/gate");
    }
}
