@page "/register"
@inject DaiNamWeb.Client.Services.AuthService Auth
@inject NavigationManager Nav

<div style="max-width:380px; margin:48px auto">
    <div class="card">
        <div class="card-header" style="text-align:center; font-size:18px"><i class="bi bi-person-plus"></i> Đăng ký tài khoản</div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert @(success ? "alert-success" : "alert-danger")">@message</div>
        }

        <div class="form-group">
            <label>Họ tên</label>
            <input class="form-control" @bind="hoTen" placeholder="Nguyễn Văn A" />
        </div>

        <div class="form-group">
            <label>Số điện thoại</label>
            <input class="form-control" @bind="sdt" placeholder="0901234567" />
        </div>

        <div class="form-group">
            <label>Mật khẩu</label>
            <input class="form-control" type="password" @bind="pass" />
        </div>

        <button class="btn btn-gold btn-lg" style="width:100%" @onclick="DoRegister" disabled="@loading">
            @(loading ? "Đang xử lý..." : "Đăng ký")
        </button>

        <div style="text-align:center; margin-top:var(--sp-16); font-size:13px; color:var(--outline)">
            Đã có tài khoản? <a href="/login" style="color:var(--tertiary); font-weight:600">Đăng nhập</a>
        </div>
    </div>
</div>

@code {
    string hoTen = "", sdt = "", pass = "", message = "";
    bool loading, success;

    async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(hoTen) || string.IsNullOrWhiteSpace(sdt) || string.IsNullOrWhiteSpace(pass))
        {
            message = "Vui lòng nhập đầy đủ thông tin!";
            success = false;
            return;
        }
        loading = true;
        var (ok, msg) = await Auth.Register(sdt, pass, hoTen);
        message = msg;
        success = ok;
        loading = false;
        if (ok) Nav.NavigateTo("/");
    }
}
