@page "/"

<div class="hero">
    <h1>Chào mừng đến Đại Nam Resort</h1>
    <p class="hero-sub">Trải nghiệm khu du lịch hàng đầu Việt Nam</p>
    <div class="hero-actions">
        <a href="/buy-ticket" class="btn-hero btn-ticket">
            <i class="bi bi-ticket-perforated-fill"></i> Mua vé tham quan
        </a>
        <a href="/book-hotel" class="btn-hero btn-hotel">
            <i class="bi bi-building-fill"></i> Đặt phòng khách sạn
        </a>
    </div>
</div>

<div class="features">
    <div class="feature-card">
        <i class="bi bi-qr-code feature-icon"></i>
        <h3>Vé điện tử</h3>
        <p>Mua vé online, quét mã QR vào cổng nhanh chóng</p>
    </div>
    <div class="feature-card">
        <i class="bi bi-calendar2-check feature-icon"></i>
        <h3>Đặt phòng</h3>
        <p>Chọn loại phòng, đặt cọc online, check-in tại quầy</p>
    </div>
    <div class="feature-card">
        <i class="bi bi-gem feature-icon"></i>
        <h3>Tích điểm</h3>
        <p>Đăng ký thành viên, tích D-Point mỗi giao dịch</p>
    </div>
</div>
