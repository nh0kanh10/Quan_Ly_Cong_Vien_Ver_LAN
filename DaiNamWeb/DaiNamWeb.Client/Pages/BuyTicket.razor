@page "/buy-ticket"
@inject TicketService TicketSvc
@inject AuthService Auth
@inject NavigationManager Nav

<h2><i class="bi bi-ticket-perforated"></i> Mua vé tham quan</h2>

@if (products == null)
{
    <p><i class="bi bi-arrow-repeat spin"></i> Đang tải danh sách vé...</p>
}
else if (!products.Any())
{
    <p>Hiện chưa có vé nào đang bán.</p>
}
else
{
    <div class="ticket-grid">
        @foreach (var sp in products)
        {
            var qty = cart.ContainsKey(sp.Id) ? cart[sp.Id] : 0;
            <div class="ticket-card">
                <div class="ticket-type">
                    <i class="bi @(sp.LoaiSanPham == "VeVaoKhu" ? "bi-door-open" : "bi-controller")"></i>
                    @(sp.LoaiSanPham == "VeVaoKhu" ? "Vé vào khu" : "Vé trò chơi")
                </div>
                <h3>@sp.TenSanPham</h3>
                @if (!string.IsNullOrEmpty(sp.TenKhuVuc))
                {
                    <p class="ticket-area"><i class="bi bi-geo-alt"></i> @sp.TenKhuVuc</p>
                }
                <p class="ticket-price">@sp.DonGia.ToString("N0") ₫</p>
                <div class="qty-control">
                    <button @onclick="() => ChangeQty(sp.Id, -1)" disabled="@(qty == 0)">
                        <i class="bi bi-dash"></i>
                    </button>
                    <span>@qty</span>
                    <button @onclick="() => ChangeQty(sp.Id, 1)">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
            </div>
        }
    </div>

    @if (cart.Any(x => x.Value > 0))
    {
        <div class="cart-summary">
            <h3><i class="bi bi-cart3"></i> Giỏ hàng</h3>
            @foreach (var item in cart.Where(x => x.Value > 0))
            {
                var sp = products.First(p => p.Id == item.Key);
                <div class="cart-row">
                    <span>@sp.TenSanPham × @item.Value</span>
                    <span>@((sp.DonGia * item.Value).ToString("N0")) ₫</span>
                </div>
            }
            <div class="cart-total">
                <strong>Tổng: @TongTien.ToString("N0") ₫</strong>
            </div>
            <button class="btn-primary" @onclick="DoPurchase" disabled="@purchasing">
                @if (purchasing)
                {
                    <i class="bi bi-arrow-repeat spin"></i> <span> Đang xử lý...</span>
                }
                else
                {
                    <i class="bi bi-credit-card"></i> <span> Thanh toán (giả lập)</span>
                }
            </button>
        </div>
    }

    @if (result != null)
    {
        <div class="purchase-result">
            <h3><i class="bi bi-check-circle-fill"></i> Mua vé thành công!</h3>
            <p>Mã đơn: <strong>@result.MaDonHang</strong></p>
            <p>Tổng thanh toán: <strong>@result.TongTien.ToString("N0") ₫</strong></p>
            <h4>Vé của bạn:</h4>
            @foreach (var ve in result.Tickets)
            {
                <div class="ticket-result">
                    <span>@ve.TenSanPham</span>
                    <code>@ve.MaVach</code>
                </div>
            }
        </div>
    }
}

@if (!string.IsNullOrEmpty(errorMsg))
{
    <div class="alert alert-err"><i class="bi bi-exclamation-circle"></i> @errorMsg</div>
}

@code {
    List<TicketProduct>? products;
    Dictionary<int, int> cart = new();
    PurchaseResult? result;
    bool purchasing;
    string errorMsg = "";

    decimal TongTien => cart.Where(x => x.Value > 0)
        .Sum(x => (products?.FirstOrDefault(p => p.Id == x.Key)?.DonGia ?? 0) * x.Value);

    protected override async Task OnInitializedAsync()
    {
        products = await TicketSvc.GetProducts();
    }

    void ChangeQty(int id, int delta)
    {
        if (!cart.ContainsKey(id)) cart[id] = 0;
        cart[id] = Math.Max(0, cart[id] + delta);
        result = null; errorMsg = "";
    }

    async Task DoPurchase()
    {
        if (!Auth.IsLoggedIn) { Nav.NavigateTo("/login"); return; }
        purchasing = true; errorMsg = "";
        var items = cart.Where(x => x.Value > 0)
            .Select(x => new CartItem(x.Key, x.Value)).ToList();
        result = await TicketSvc.Purchase(new PurchaseRequest(items, Auth.CurrentUser!.IdTaiKhoan));
        if (result == null) errorMsg = "Thanh toán thất bại. Vui lòng thử lại.";
        else cart.Clear();
        purchasing = false;
    }
}
